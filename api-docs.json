{
  "openapi": "3.0.3",
  "info": {
    "title": "Coletor Patrimonial API",
    "version": "1.0.0",
    "description": "Documentacao OpenAPI da API do Coletor Patrimonial. A autenticacao protegida usa JWT no header `Authorization: Bearer <token>`. O token precisa conter `uid` e `tenantId` validos.",
    "contact": {
      "name": "Coletor Patrimonial Team"
    }
  },
  "servers": [
    {
      "url": "http://localhost:3000",
      "description": "Servidor local"
    }
  ],
  "tags": [
    {
      "name": "Health",
      "description": "Monitoramento basico da API e banco local"
    },
    {
      "name": "Auth",
      "description": "Autenticacao, emissao e renovacao de tokens JWT"
    },
    {
      "name": "Users",
      "description": "Perfil e exclusao do usuario autenticado"
    },
    {
      "name": "Inventory",
      "description": "Consulta, manutencao e sincronizacao de bens do inventario"
    },
    {
      "name": "Catalogs",
      "description": "Catalogos derivados dos dados do inventario"
    }
  ],
  "security": [
    {
      "bearerAuth": []
    }
  ],
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT",
        "description": "Token JWT retornado pelos endpoints de autenticacao."
      }
    },
    "parameters": {
      "TenantHeader": {
        "name": "x-tenant-id",
        "in": "header",
        "required": false,
        "description": "Tenant alternativo aceito no registro. Tambem pode ser enviado no corpo como `tenantId`, `tenant_id` ou `cnpj`.",
        "schema": {
          "type": "string"
        }
      },
      "InventoryId": {
        "name": "id",
        "in": "path",
        "required": true,
        "description": "ID do item de inventario.",
        "schema": {
          "type": "string",
          "minLength": 1
        }
      },
      "UserId": {
        "name": "id",
        "in": "path",
        "required": true,
        "description": "ID do usuario. A API so permite excluir a propria conta autenticada.",
        "schema": {
          "type": "string"
        }
      },
      "InventoryCode": {
        "name": "code",
        "in": "path",
        "required": true,
        "description": "Codigo ou placa do bem.",
        "schema": {
          "type": "string",
          "minLength": 1
        }
      },
      "Page": {
        "name": "page",
        "in": "query",
        "required": false,
        "description": "Pagina da listagem.",
        "schema": {
          "type": "integer",
          "minimum": 1,
          "default": 1
        }
      },
      "Limit": {
        "name": "limit",
        "in": "query",
        "required": false,
        "description": "Quantidade maxima de itens por pagina.",
        "schema": {
          "type": "integer",
          "minimum": 1,
          "maximum": 1000,
          "default": 50
        }
      },
      "Since": {
        "name": "since",
        "in": "query",
        "required": false,
        "description": "Filtro por data ISO8601 usando `updatedAt >= since`.",
        "schema": {
          "type": "string",
          "format": "date-time"
        }
      },
      "SearchQ": {
        "name": "q",
        "in": "query",
        "required": false,
        "description": "Prefixo de busca.",
        "schema": {
          "type": "string",
          "minLength": 1
        }
      },
      "SearchField": {
        "name": "field",
        "in": "query",
        "required": false,
        "description": "Campo pesquisado. O alias `local` mapeia para `localizacaoNome`.",
        "schema": {
          "type": "string",
          "enum": [
            "codigo",
            "placa",
            "descricao",
            "local"
          ]
        }
      },
      "NrInventario": {
        "name": "nrInventario",
        "in": "query",
        "required": false,
        "description": "Numero do inventario usado para escopo de consulta, catalogos, busca por codigo e exportacao.",
        "schema": {
          "type": "string",
          "minLength": 1
        }
      },
      "NrInventarioRequired": {
        "name": "nrInventario",
        "in": "query",
        "required": true,
        "description": "Numero do inventario.",
        "schema": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "schemas": {
      "ValidationErrorDetail": {
        "type": "object",
        "properties": {
          "type": {
            "type": "string",
            "example": "field"
          },
          "value": {
            "nullable": true
          },
          "msg": {
            "type": "string",
            "example": "Senha deve ter pelo menos 6 caracteres"
          },
          "path": {
            "type": "string",
            "example": "password"
          },
          "location": {
            "type": "string",
            "example": "body"
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "required": [
          "error",
          "message"
        ],
        "properties": {
          "error": {
            "type": "string",
            "example": "Dados invalidados"
          },
          "message": {
            "type": "string",
            "example": "Verifique os dados enviados"
          },
          "details": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/ValidationErrorDetail"
            }
          },
          "stack": {
            "type": "string",
            "description": "Disponivel apenas em desenvolvimento."
          }
        }
      },
      "HealthResponse": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string",
            "example": "OK"
          },
          "timestamp": {
            "type": "string",
            "format": "date-time"
          },
          "uptime": {
            "type": "number",
            "example": 1234.56
          },
          "environment": {
            "type": "string",
            "example": "development"
          },
          "database": {
            "type": "string",
            "enum": [
              "available",
              "unavailable"
            ]
          }
        }
      },
      "AuthUser": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "example": "mcf42g8c-a1b2c3"
          },
          "uid": {
            "type": "string",
            "example": "mcf42g8c-a1b2c3"
          },
          "email": {
            "type": "string",
            "format": "email",
            "example": "inventario@empresa.com.br"
          },
          "name": {
            "type": "string",
            "example": "Marcelo"
          },
          "fullName": {
            "type": "string",
            "example": "Marcelo Dev"
          },
          "tenantId": {
            "type": "string",
            "nullable": true,
            "example": "12345678000199"
          },
          "createdAt": {
            "type": "string",
            "format": "date-time"
          },
          "updatedAt": {
            "type": "string",
            "format": "date-time",
            "nullable": true
          }
        }
      },
      "LoginRequest": {
        "type": "object",
        "required": [
          "email",
          "password"
        ],
        "properties": {
          "email": {
            "type": "string",
            "format": "email"
          },
          "password": {
            "type": "string",
            "minLength": 6
          }
        },
        "example": {
          "email": "inventario@empresa.com.br",
          "password": "123456"
        }
      },
      "RegisterRequest": {
        "type": "object",
        "description": "O backend exige email, senha, um nome (`name` ou `fullName`) e um tenant (`tenantId`, `tenant_id`, `cnpj` ou header `x-tenant-id`).",
        "required": [
          "email",
          "password"
        ],
        "properties": {
          "email": {
            "type": "string",
            "format": "email"
          },
          "password": {
            "type": "string",
            "minLength": 6
          },
          "name": {
            "type": "string",
            "minLength": 2
          },
          "fullName": {
            "type": "string",
            "minLength": 2
          },
          "tenantId": {
            "type": "string"
          },
          "tenant_id": {
            "type": "string"
          },
          "cnpj": {
            "type": "string"
          }
        },
        "example": {
          "email": "inventario@empresa.com.br",
          "password": "123456",
          "fullName": "Marcelo Dev",
          "tenantId": "12345678000199"
        }
      },
      "AuthResponse": {
        "type": "object",
        "properties": {
          "success": {
            "type": "boolean",
            "example": true
          },
          "message": {
            "type": "string",
            "example": "Login realizado com sucesso"
          },
          "data": {
            "type": "object",
            "properties": {
              "token": {
                "type": "string"
              },
              "refreshToken": {
                "type": "string"
              },
              "user": {
                "$ref": "#/components/schemas/AuthUser"
              }
            }
          }
        }
      },
      "RefreshTokenRequest": {
        "type": "object",
        "required": [
          "refreshToken"
        ],
        "properties": {
          "refreshToken": {
            "type": "string"
          }
        },
        "example": {
          "refreshToken": "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9..."
        }
      },
      "RefreshTokenResponse": {
        "type": "object",
        "properties": {
          "success": {
            "type": "boolean",
            "example": true
          },
          "message": {
            "type": "string",
            "example": "Token renovado com sucesso"
          },
          "data": {
            "type": "object",
            "properties": {
              "token": {
                "type": "string"
              }
            }
          }
        }
      },
      "LogoutResponse": {
        "type": "object",
        "properties": {
          "success": {
            "type": "boolean",
            "example": true
          },
          "message": {
            "type": "string",
            "example": "Logout realizado com sucesso"
          }
        }
      },
      "MeResponse": {
        "type": "object",
        "properties": {
          "success": {
            "type": "boolean",
            "example": true
          },
          "data": {
            "type": "object",
            "properties": {
              "user": {
                "$ref": "#/components/schemas/AuthUser"
              },
              "authType": {
                "type": "string",
                "example": "jwt"
              }
            }
          }
        }
      },
      "ProfileResponse": {
        "type": "object",
        "properties": {
          "success": {
            "type": "boolean",
            "example": true
          },
          "data": {
            "type": "object",
            "properties": {
              "user": {
                "type": "object",
                "description": "Payload bruto do token autenticado."
              },
              "authType": {
                "type": "string",
                "example": "jwt"
              }
            }
          }
        }
      },
      "UpdateProfileRequest": {
        "type": "object",
        "description": "Envie `name` ou `fullName`.",
        "properties": {
          "name": {
            "type": "string",
            "minLength": 1
          },
          "fullName": {
            "type": "string",
            "minLength": 1
          }
        },
        "example": {
          "fullName": "Marcelo Almeida"
        }
      },
      "UpdateProfileResponse": {
        "type": "object",
        "properties": {
          "success": {
            "type": "boolean",
            "example": true
          },
          "message": {
            "type": "string",
            "example": "Perfil atualizado com sucesso"
          },
          "data": {
            "type": "object",
            "properties": {
              "user": {
                "type": "object",
                "properties": {
                  "id": {
                    "type": "string"
                  },
                  "uid": {
                    "type": "string"
                  },
                  "email": {
                    "type": "string",
                    "format": "email"
                  },
                  "name": {
                    "type": "string"
                  },
                  "fullName": {
                    "type": "string"
                  },
                  "updatedAt": {
                    "type": "string",
                    "format": "date-time"
                  }
                }
              }
            }
          }
        }
      },
      "DeleteUserResponse": {
        "type": "object",
        "properties": {
          "success": {
            "type": "boolean",
            "example": true
          },
          "message": {
            "type": "string",
            "example": "Usuario excluido com sucesso"
          },
          "data": {
            "type": "object",
            "properties": {
              "firebaseDeleted": {
                "type": "boolean",
                "example": false
              }
            }
          }
        }
      },
      "CatalogItem": {
        "type": "object",
        "properties": {
          "codigo": {
            "type": "string",
            "nullable": true,
            "example": "0101"
          },
          "nome": {
            "type": "string",
            "example": "ALMOXARIFADO CENTRAL"
          }
        }
      },
      "CatalogResponse": {
        "type": "object",
        "properties": {
          "success": {
            "type": "boolean",
            "example": true
          },
          "data": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/CatalogItem"
            }
          }
        }
      },
      "InventoryItem": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "example": "mcf42g8c-a1b2c3"
          },
          "codigo": {
            "type": "string",
            "nullable": true
          },
          "placa": {
            "type": "string",
            "nullable": true
          },
          "descricao": {
            "type": "string",
            "nullable": true
          },
          "localizacaoNome": {
            "type": "string",
            "nullable": true
          },
          "situacaoNome": {
            "type": "string",
            "nullable": true
          },
          "estadoConservacaoNome": {
            "type": "string",
            "nullable": true
          },
          "dsObservacao": {
            "type": "string",
            "nullable": true
          },
          "codigoLocalizacao": {
            "type": "string",
            "nullable": true
          },
          "codigoSituacao": {
            "type": "string",
            "nullable": true
          },
          "codigoEstado": {
            "type": "string",
            "nullable": true
          },
          "nrInventario": {
            "type": "string",
            "nullable": true
          },
          "valorAtual": {
            "type": "number",
            "nullable": true,
            "example": 2499.9
          },
          "inventariadoPor": {
            "type": "string",
            "nullable": true,
            "example": "Marcelo"
          },
          "StatusBem": {
            "type": "string",
            "nullable": true,
            "example": "Bem Inventariado"
          },
          "statusBem": {
            "type": "string",
            "nullable": true,
            "example": "Bem Inventariado"
          },
          "status": {
            "type": "string",
            "nullable": true,
            "example": "Bem Inventariado"
          },
          "createdAt": {
            "type": "string",
            "format": "date-time",
            "nullable": true
          },
          "updatedAt": {
            "type": "string",
            "format": "date-time",
            "nullable": true
          }
        }
      },
      "InventoryPayload": {
        "type": "object",
        "description": "Payload aceito pelo backend. A API aceita tanto os nomes canonicos quanto aliases legados para localizacao, situacao, estado e observacao.",
        "properties": {
          "id": {
            "type": "string",
            "description": "Opcional no sync para conciliacao por ID."
          },
          "codigo": {
            "type": "string"
          },
          "placa": {
            "type": "string"
          },
          "descricao": {
            "type": "string"
          },
          "localizacaoNome": {
            "type": "string"
          },
          "localizacao": {
            "type": "string"
          },
          "local": {
            "type": "string"
          },
          "situacaoNome": {
            "type": "string"
          },
          "situacao": {
            "type": "string"
          },
          "estadoConservacaoNome": {
            "type": "string"
          },
          "estado": {
            "type": "string"
          },
          "dsObservacao": {
            "type": "string",
            "maxLength": 500
          },
          "observacao": {
            "type": "string",
            "maxLength": 500
          },
          "observacoes": {
            "type": "string",
            "maxLength": 500
          },
          "codigoLocalizacao": {
            "type": "string"
          },
          "cdLocalizacao": {
            "type": "string"
          },
          "codigoSituacao": {
            "type": "string"
          },
          "cdSituacao": {
            "type": "string"
          },
          "codigoEstado": {
            "type": "string"
          },
          "cdEstadoConser": {
            "type": "string"
          },
          "nrInventario": {
            "type": "string"
          },
          "valorAtual": {
            "oneOf": [
              {
                "type": "number"
              },
              {
                "type": "string",
                "example": "2.499,90"
              }
            ]
          },
          "StatusBem": {
            "type": "string"
          },
          "statusBem": {
            "type": "string"
          },
          "status": {
            "type": "string"
          },
          "inventariadoPor": {
            "type": "string"
          },
          "createdAt": {
            "type": "string",
            "format": "date-time"
          },
          "updatedAt": {
            "type": "string",
            "format": "date-time"
          }
        },
        "example": {
          "codigo": "123456",
          "placa": "000012345678",
          "descricao": "Notebook Dell Latitude",
          "local": "ALMOXARIFADO CENTRAL",
          "situacao": "EM USO",
          "estado": "BOM",
          "observacoes": "Patrimonio localizado na prateleira 3",
          "cdLocalizacao": "0101",
          "cdSituacao": "01",
          "cdEstadoConser": "01",
          "nrInventario": "2026-0001",
          "valorAtual": "2.499,90",
          "statusBem": "Bem Inventariado",
          "inventariadoPor": "Marcelo Dev"
        }
      },
      "InventoryPagination": {
        "type": "object",
        "properties": {
          "page": {
            "type": "integer",
            "example": 1
          },
          "limit": {
            "type": "integer",
            "example": 50
          },
          "total": {
            "type": "integer",
            "example": 182
          },
          "totalPages": {
            "type": "integer",
            "example": 4
          }
        }
      },
      "InventoryListResponse": {
        "type": "object",
        "properties": {
          "success": {
            "type": "boolean",
            "example": true
          },
          "data": {
            "type": "object",
            "properties": {
              "items": {
                "type": "array",
                "items": {
                  "$ref": "#/components/schemas/InventoryItem"
                }
              },
              "pagination": {
                "$ref": "#/components/schemas/InventoryPagination"
              }
            }
          }
        }
      },
      "InventorySingleResponse": {
        "type": "object",
        "properties": {
          "success": {
            "type": "boolean",
            "example": true
          },
          "data": {
            "$ref": "#/components/schemas/InventoryItem"
          }
        }
      },
      "InventoryMutationResponse": {
        "type": "object",
        "properties": {
          "success": {
            "type": "boolean",
            "example": true
          },
          "message": {
            "type": "string",
            "example": "Item atualizado com sucesso"
          },
          "data": {
            "$ref": "#/components/schemas/InventoryItem"
          },
          "skipped": {
            "type": "boolean",
            "description": "Pode aparecer em atualizacoes protegidas por regra de negocio.",
            "example": false
          }
        }
      },
      "InventoryDeleteResponse": {
        "type": "object",
        "properties": {
          "success": {
            "type": "boolean",
            "example": true
          },
          "message": {
            "type": "string",
            "example": "Item deletado com sucesso"
          }
        }
      },
      "InventoryBulkDeleteResponse": {
        "type": "object",
        "properties": {
          "success": {
            "type": "boolean",
            "example": true
          },
          "message": {
            "type": "string",
            "example": "Itens do inventario deletados"
          },
          "removed": {
            "type": "integer",
            "example": 42
          }
        }
      },
      "InventorySyncRequest": {
        "type": "object",
        "required": [
          "items"
        ],
        "properties": {
          "items": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/InventoryPayload"
            }
          }
        }
      },
      "InventorySyncResultItem": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "action": {
            "type": "string",
            "enum": [
              "created",
              "updated",
              "updated-inventariado"
            ]
          }
        }
      },
      "InventorySyncResponse": {
        "type": "object",
        "properties": {
          "success": {
            "type": "boolean",
            "example": true
          },
          "message": {
            "type": "string",
            "example": "Sincronizacao realizada com sucesso"
          },
          "data": {
            "type": "object",
            "properties": {
              "results": {
                "type": "array",
                "items": {
                  "$ref": "#/components/schemas/InventorySyncResultItem"
                }
              },
              "total": {
                "type": "integer",
                "example": 2
              }
            }
          }
        }
      }
    },
    "responses": {
      "ValidationError": {
        "description": "Falha de validacao do request.",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/ErrorResponse"
            }
          }
        }
      },
      "Unauthorized": {
        "description": "Token ausente, invalido, expirado ou sem tenant valido.",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/ErrorResponse"
            }
          }
        }
      },
      "Forbidden": {
        "description": "Operacao nao permitida para o usuario autenticado.",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/ErrorResponse"
            }
          }
        }
      },
      "NotFound": {
        "description": "Recurso nao encontrado.",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/ErrorResponse"
            }
          }
        }
      },
      "ServerError": {
        "description": "Erro interno do servidor.",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/ErrorResponse"
            }
          }
        }
      }
    }
  },
  "paths": {
    "/health": {
      "get": {
        "tags": [
          "Health"
        ],
        "summary": "Health check da API",
