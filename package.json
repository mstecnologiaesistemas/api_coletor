{
  "name": "coletor-patrimonial-api",
  "version": "1.0.0",
  "description": "API Backend para o Coletor de Dados Patrimoniais",
  "main": "src/server.js",
  "bin": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "test": "jest",
    "build:exe": "pkg . --targets node18-win-x64 --out-path dist",
    "build:exe:all": "pkg . --targets node18-win-x64,node18-linux-x64,node18-macos-x64 --out-path dist"
  },
  "keywords": [
    "api",
    "backend",
    "patrimonio",
    "inventario"
  ],
  "author": "Coletor Patrimonial Team",
  "license": "MIT",
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "better-sqlite3": "^12.4.1",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "express-validator": "^7.0.1",
    "firebase-admin": "^11.11.1",
    "@grpc/proto-loader": "^0.7.5",
    "protobufjs": "^7.2.0",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "nodemon": "^3.0.2",
    "pkg": "^5.8.1",
    "supertest": "^6.3.3"
  },
  "engines": {
    "node": ">=16.0.0"
  },
  "pkg": {
    "scripts": [
      "config/**/*.js",
      "controllers/**/*.js",
      "db/**/*.js",
      "middleware/**/*.js",
      "repositories/**/*.js",
      "routes/**/*.js",
      "src/**/*.js"
    ],
    "targets": [
      "node18-win-x64"
    ],
    "outputPath": "dist",
    "assets": [
      "api-docs.json",
      "src/docs/**/*",
      "node_modules/better-sqlite3/build/Release/*.node"
    ]
  }
}
